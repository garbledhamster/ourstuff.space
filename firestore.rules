rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isCloudUser() {
      return signedIn() && request.auth.token.cloud == true;
    }

    function isOwnerUid(uid) {
      return signedIn()
        && request.auth.uid == uid
        && uid in ["hLyXXFx6MTYx3Hu35MESD0Gw77C2"];
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasCloudProfile(uid) {
      return isSelf(uid)
        && exists(/databases/$(database)/documents/users/$(uid))
        && (
          get(/databases/$(database)/documents/users/$(uid)).data.cloud == true
          || get(/databases/$(database)/documents/users/$(uid)).data.admin == true
        );
    }

    function canUseCloud(uid) {
      return isAdmin()
        || (
          isSelf(uid)
          && (isCloudUser() || isOwnerUid(uid) || hasCloudProfile(uid))
        );
    }

    function ownsIncomingArtifact(uid) {
      return request.resource.data.owner == uid
        && request.auth.uid in request.resource.data.acl.owners;
    }

    match /users/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid}/apps/{appId} {
      allow read: if canUseCloud(uid);
      allow create, update, delete: if canUseCloud(uid);
    }

    match /users/{uid}/apps/{appId}/artifacts/{artifactId} {
      allow read: if canUseCloud(uid);
      allow create, update: if canUseCloud(uid) && ownsIncomingArtifact(uid);
      allow delete: if canUseCloud(uid);
    }
  }
}
