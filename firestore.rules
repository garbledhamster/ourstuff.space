rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function canUseCloud(uid) {
      return isAdmin() || isSelf(uid);
    }

    function ownsExistingOwnerUid() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsIncomingArtifact(uid) {
      return request.resource.data.owner == uid
        && request.resource.data.acl is map
        && request.resource.data.acl.owners is list
        && request.auth.uid in request.resource.data.acl.owners;
    }

    function isProtectedAppCollection(collectionId) {
      return collectionId in [
        "artifacts",
        "pyxdiaSettings",
        "pyxdiaThreads",
        "pyxdiaLetters",
        "pyxdiaMemories",
        "pyxdiaProcessingJobs",
        "pyxdiaRateLimits"
      ];
    }

    match /brain_memories/{memoryId} {
      allow read: if ownsExistingOwnerUid();
      allow create, update, delete: if false;
    }

    match /brain_artifacts/{artifactId} {
      allow read: if ownsExistingOwnerUid()
        && resource.data.sensitivity != "restricted";
      allow create, update, delete: if false;
    }

    match /context_bundles/{bundleId} {
      allow read: if ownsExistingOwnerUid();
      allow create, update, delete: if false;
    }

    match /projects/{projectId} {
      allow read: if ownsExistingOwnerUid();
      allow create, update, delete: if false;
    }

    match /audit_events/{eventId} {
      allow read: if ownsExistingOwnerUid();
      allow create, update, delete: if false;
    }

    match /tenants/{tenantId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /users/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid}/settings/{settingId} {
      allow read: if isSelf(uid);
      allow create, update, delete: if false;
    }

    match /users/{uid}/trash/{trashItemId} {
      allow read: if isSelf(uid);
      allow create, update, delete: if false;
    }

    match /users/{uid}/apps/{appId} {
      allow read: if canUseCloud(uid);
      allow create, update, delete: if canUseCloud(uid);
    }

    match /users/{uid}/apps/{appId}/{collectionId}/{document=**} {
      allow read, create, update, delete: if canUseCloud(uid)
        && !isProtectedAppCollection(collectionId);
    }

    match /users/{uid}/apps/{appId}/artifacts/{artifactId} {
      allow read: if canUseCloud(uid);
      allow create, update: if canUseCloud(uid) && ownsIncomingArtifact(uid);
      allow delete: if canUseCloud(uid);
    }

    match /users/{uid}/apps/{appId}/pyxdiaSettings/{docId} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid)
        && request.resource.data.owner == uid
        && !("admin" in request.resource.data);
      allow delete: if isSelf(uid);
    }

    match /users/{uid}/apps/{appId}/pyxdiaThreads/{threadId} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid)
        && request.resource.data.owner == uid;
      allow delete: if isSelf(uid);
    }

    match /users/{uid}/apps/{appId}/pyxdiaLetters/{letterId} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid)
        && request.resource.data.owner == uid
        && request.resource.data.state == "draft"
        && !("outputText" in request.resource.data);
      allow delete: if isSelf(uid);
    }

    match /users/{uid}/apps/{appId}/pyxdiaMemories/{memoryId} {
      allow read, delete: if isSelf(uid);
      allow create, update: if false;
    }

    match /users/{uid}/apps/{appId}/pyxdiaProcessingJobs/{jobId} {
      allow read: if isSelf(uid);
      allow create, update, delete: if false;
    }

    match /users/{uid}/apps/{appId}/pyxdiaRateLimits/{bucketId} {
      allow read, create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
